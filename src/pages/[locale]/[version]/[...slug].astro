---
import { getCollection, render } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import Sidebar from "../../../components/layout/Sidebar.astro";
import TOC from "../../../components/layout/TOC.astro";
import CopyForAI from "../../../components/CopyForAI.astro";
import PrevNext from "../../../components/layout/PrevNext.astro";
import VersionPicker from "../../../components/VersionPicker.astro";
import LocalePicker from "../../../components/LocalePicker.astro";
import ThemeToggle from "../../../components/ThemeToggle.astro";
import { parseEntryId, buildDocHref } from "../../../lib/routing";
import { sliceSections, buildContextHeader } from "../../../lib/ai-content";
import { docsConfig } from "../../../docs.config";

export async function getStaticPaths() {
  const entries = await getCollection("docs");
  return entries.map((entry) => {
    const parsed = parseEntryId(entry.id);
    return {
      params: {
        locale: parsed.locale,
        version: parsed.version,
        slug: parsed.slug || undefined,
      },
      props: { entry, parsed },
    };
  });
}

const { entry, parsed } = Astro.props;
const { Content, headings } = await render(entry);
const currentHref = buildDocHref(parsed);
const mdUrl = `${currentHref.replace(/\/$/, "")}.md`;
const canonicalUrl = docsConfig.site.url + currentHref;

const sections = sliceSections(entry.body as string).map((s) => ({
  anchor: s.anchor,
  payload:
    buildContextHeader({
      url: canonicalUrl,
      version: parsed.version,
      locale: parsed.locale,
      anchor: s.anchor,
    }) + s.markdown,
}));
---
<Layout
  title={entry.data.title}
  description={entry.data.description}
  locale={parsed.locale}
  version={parsed.version}
  slug={parsed.slug}
>
  <div class="shell">
    <aside class="col-sidebar" aria-label="Documentation navigation">
      <div class="sidebar-main">
        <Sidebar locale={parsed.locale} version={parsed.version} currentHref={currentHref} />
      </div>
      <div class="mobile-footer">
        <VersionPicker currentLocale={parsed.locale} currentVersion={parsed.version} />
        <div class="mobile-footer-right">
          <LocalePicker currentLocale={parsed.locale} currentVersion={parsed.version} currentSlug={parsed.slug} />
          <ThemeToggle />
        </div>
      </div>
    </aside>
    <main class="col-content" data-pagefind-body data-pagefind-filter={`version:${parsed.version}`} lang={parsed.locale}>
      <article class="prose">
        <header class="page-header">
          <h1 data-pagefind-meta="title">{entry.data.title}</h1>
          <CopyForAI url={mdUrl} />
        </header>
        <Content />
      </article>
      <PrevNext locale={parsed.locale} version={parsed.version} currentHref={currentHref} />
      {sections.map((s) => (
        <template id={`section-md-${s.anchor}`} data-payload={JSON.stringify(s.payload)}></template>
      ))}
    </main>
    <aside class="col-toc" aria-label="On this page">
      <TOC headings={headings} />
    </aside>
  </div>
</Layout>

<script define:vars={{ mdUrl }}>
  document.querySelectorAll("article.prose h2[data-section-heading]").forEach((h2) => {
    if (h2.querySelector(".copy-ai")) return;
    const anchor = h2.getAttribute("data-section-heading");
    const btn = document.createElement("button");
    btn.type = "button";
    btn.className = "copy-ai section";
    btn.setAttribute("data-copy-ai", "");
    btn.setAttribute("data-copy-ai-url", mdUrl);
    btn.setAttribute("data-copy-ai-anchor", anchor);
    btn.setAttribute("aria-label", `Copy section "${h2.textContent}" for AI`);
    const span = document.createElement("span");
    span.setAttribute("data-copy-ai-label", "");
    span.textContent = "Copy";
    btn.appendChild(span);
    h2.appendChild(btn);
  });
</script>

<script>
  import { initCopyForAI } from "../../../scripts/copy-ai.ts";
  import { initCodeCopy } from "../../../scripts/code-copy.ts";
  initCopyForAI();
  initCodeCopy();
</script>

<style>
  .shell {
    display: grid;
    grid-template-columns: var(--sidebar-w) minmax(0, 1fr) var(--toc-w);
    max-width: var(--shell-max);
    margin: 0 auto;
    min-height: calc(100vh - var(--header-h));
  }
  .col-sidebar {
    position: sticky;
    top: var(--header-h);
    align-self: start;
    max-height: calc(100vh - var(--header-h));
    overflow-y: auto;
  }
  .sidebar-main {
    display: block;
  }
  .mobile-footer {
    display: none;
  }
  .col-content {
    padding: var(--gutter) calc(var(--gutter) * 2);
    min-width: 0;
  }
  .col-toc {
  }
  .page-header {
    display: flex;
    align-items: center;
    gap: var(--gutter);
    margin-bottom: 1.5em;
  }
  .page-header h1 {
    margin: 0;
    flex: 1;
  }
  @media (max-width: 1024px) {
    .shell {
      grid-template-columns: var(--sidebar-w) 1fr;
    }
    .col-toc {
      display: none;
    }
  }
  @media (max-width: 768px) {
    .shell {
      grid-template-columns: 1fr;
    }
    .col-content {
      padding: var(--gutter);
    }
    .col-sidebar {
      display: none;
      position: fixed;
      top: var(--header-h);
      left: 0;
      right: 0;
      bottom: 0;
      width: 100vw;
      height: calc(100dvh - var(--header-h));
      background: var(--color-bg-inner);
      z-index: calc(var(--z-header) - 1);
      max-height: none;
      overflow: hidden;
      flex-direction: column;
    }
    :global(body[data-sidebar-open="true"]) .col-sidebar {
      display: flex;
    }
    .sidebar-main {
      flex: 1;
      overflow-y: auto;
    }
    .mobile-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px var(--gutter);
      border-top: 1px solid var(--color-lines);
      background: var(--color-bg-inner);
      flex-shrink: 0;
    }
    .mobile-footer-right {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .mobile-footer :global(.dropdown-menu) {
      top: auto;
      bottom: calc(100% + 6px);
    }
  }
</style>
