---
import { docsConfig } from "../config/docs.config";
import Dropdown from "./Dropdown.astro";
import Icon from "./Icon.astro";

interface Props {
  currentLocale: string;
  currentVersion: string;
  currentSlug: string;
}
const { currentLocale, currentVersion, currentSlug } = Astro.props;
---
<Dropdown id="locale" align="right" triggerClass="icon-trigger" label="Change language">
  <Fragment slot="trigger">
    <Icon name="languages" size={16} />
  </Fragment>
  <Fragment slot="menu">
    {docsConfig.i18n.locales.map((l) => {
      const href = `/${l.code}/${currentVersion}/${currentSlug}${currentSlug ? "/" : ""}`;
      return (
        <a href={href} class={l.code === currentLocale ? "active" : ""}>{l.label}</a>
      );
    })}
  </Fragment>
</Dropdown>

<style>
  :global(.dropdown-trigger.icon-trigger) {
    width: 32px;
    height: 32px;
    padding: 0;
    justify-content: center;
  }
</style>
