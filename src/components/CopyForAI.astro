---
import Icon from "./primitives/Icon.astro";

interface Props {
  url: string;
  anchor?: string;
  label?: string;
}
const { url, anchor, label = "Copy for AI" } = Astro.props;
---
<button
  type="button"
  class="copy-ai"
  data-copy-ai
  data-copy-ai-url={url}
  data-copy-ai-anchor={anchor}
  aria-label="Copy this content as markdown for an AI assistant"
>
  <Icon name="copy" size={14} />
  <span data-copy-ai-label>{label}</span>
</button>

<style>
  .copy-ai {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--fs-xs);
    padding: .375em .75em;
    border: 1px solid var(--color-lines);
    border-radius: var(--radius);
    color: var(--color-muted);
  }
  .copy-ai:hover { color: var(--color-fg); border-color: var(--color-muted); background: var(--color-bg-hover); }
  .copy-ai:disabled { opacity: .6; cursor: wait; }
</style>
