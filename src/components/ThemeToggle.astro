---
import { docsConfig } from "../config/docs.config";
import Icon from "./Icon.astro";
const defaultTheme = docsConfig.theme.default;
---
<button type="button" class="theme-toggle" data-theme-toggle aria-label="Toggle theme">
  <span class="icon-slot" data-theme-icon="dark"><Icon name="moon" size={16} /></span>
  <span class="icon-slot" data-theme-icon="light"><Icon name="sun" size={16} /></span>
  <span class="icon-slot" data-theme-icon="system"><Icon name="monitor" size={16} /></span>
</button>

<script define:vars={{ defaultTheme }}>
  import("../scripts/theme.ts").then((m) => m.initThemeToggle(defaultTheme));
</script>

<style>
  .theme-toggle {
    width: 32px;
    height: 32px;
    border-radius: var(--radius);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-muted);
  }
  .theme-toggle:hover { background: var(--color-surface-hover); color: var(--color-fg); }
  .icon-slot { display: none; align-items: center; justify-content: center; }
  :global(html[data-theme-pref="dark"]) .icon-slot[data-theme-icon="dark"],
  :global(html[data-theme-pref="light"]) .icon-slot[data-theme-icon="light"],
  :global(html[data-theme-pref="system"]) .icon-slot[data-theme-icon="system"] {
    display: inline-flex;
  }
</style>
