---
import { docsConfig } from "../../docs.config";
import LocalePicker from "../LocalePicker.astro";
import VersionPicker from "../VersionPicker.astro";
import ThemeToggle from "../ThemeToggle.astro";
import Search from "../Search.astro";
import Icon from "../primitives/Icon.astro";

interface Props {
  currentLocale: string;
  currentVersion: string;
  currentSlug: string;
}
const { currentLocale, currentVersion, currentSlug } = Astro.props;
const showLogo = docsConfig.site.logo.enabled;
---
<header class="header">
  <div class="inner">
    <div class="left">
      <button type="button" class="hamburger" data-mobile-nav-toggle aria-label="Toggle navigation" aria-expanded="false">
        <Icon name="menu" size={18} />
      </button>
      <a href={`/${currentLocale}/${currentVersion}/`} class="brand">
        {showLogo && (
          <img src={docsConfig.site.logo.src} alt={docsConfig.site.logo.alt} class="logo" />
        )}
        <span class="brand-text">{docsConfig.site.title}</span>
      </a>
      <VersionPicker currentLocale={currentLocale} currentVersion={currentVersion} />
    </div>
    <div class="spacer" aria-hidden="true"></div>
    <div class="right">
      <Search />
      {docsConfig.headerLinks.map((l) => (
        <a href={l.href} class="link" target={l.external ? "_blank" : undefined} rel={l.external ? "noopener" : undefined}>
          {l.label}
        </a>
      ))}
      {docsConfig.site.github && (
        <a href={docsConfig.site.github} class="link icon-link" target="_blank" rel="noopener" aria-label="GitHub">
          <Icon name="github" size={16} />
        </a>
      )}
      <LocalePicker currentLocale={currentLocale} currentVersion={currentVersion} currentSlug={currentSlug} />
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    height: var(--header-h);
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }
  .inner {
    max-width: var(--shell-max, 1280px);
    margin: 0 auto;
    height: 100%;
    padding: 0 var(--gutter);
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--gutter);
    align-items: center;
  }
  .left, .right {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
  }
  .brand { display: inline-flex; align-items: center; gap: 8px; font-weight: 600; flex-shrink: 0; }
  .brand:hover { text-decoration: none; }
  .logo { width: 20px; height: 20px; flex-shrink: 0; }
  .link {
    font-size: var(--fs-sm);
    color: var(--color-muted);
    padding: .375em .5em;
    flex-shrink: 0;
  }
  .link:hover { color: var(--color-fg); text-decoration: none; }
  .icon-link { display: inline-flex; align-items: center; }
  .hamburger {
    display: none;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    padding: 0;
    color: var(--color-muted);
    border-radius: var(--radius);
    flex-shrink: 0;
  }
  .hamburger:hover { color: var(--color-fg); background: var(--color-surface-hover); }
  @media (max-width: 768px) {
    .brand-text { display: none; }
    .hamburger { display: inline-flex; }
  }
</style>

<script>
  import { initMobileSidebar } from "../../scripts/mobile-sidebar.ts";
  initMobileSidebar();
</script>
