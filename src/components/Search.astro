---
import Icon from "./primitives/Icon.astro";
---
<button type="button" class="trigger" data-search-trigger aria-label="Search">
  <Icon name="search" size={14} />
  <span class="trigger-label">Search…</span>
  <kbd>Ctrl K</kbd>
</button>

<dialog class="dialog" data-search-dialog>
  <div class="box">
    <div class="input-row">
      <Icon name="search" size={16} />
      <input type="search" placeholder="Search docs" data-search-input aria-label="Search docs" />
    </div>
    <ul class="results" data-search-results></ul>
  </div>
</dialog>

<script>
  import { initSearch } from "../scripts/search.ts";
  initSearch();
</script>

<style>
  .trigger {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    max-width: 400px;
    min-width: 240px;
    height: var(--btn-h);
    padding: 0 4px 0 10px;
    border: 1px solid var(--color-lines);
    border-radius: var(--radius);
    color: var(--color-muted);
    font-size: var(--fs-sm);
    background: var(--color-search-bg);
    white-space: nowrap;
  }
  .trigger-label {
    flex: 1;
    text-align: left;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .trigger kbd {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    height: 20px;
    padding: 0 6px;
    border: 1px solid var(--color-lines);
    border-radius: var(--radius);
    background: var(--color-bg-inner);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .trigger:hover {
    color: var(--color-fg);
    border-color: var(--color-muted);
  }

  @media (max-width: 768px) {
    .trigger {
      width: var(--btn-h);
      min-width: 0;
      padding: 0;
      justify-content: center;
      flex-shrink: 0;
    }
    .trigger-label,
    .trigger kbd {
      display: none;
    }
  }

  .dialog {
    padding: 0;
    border: none;
    background: transparent;
    max-width: 640px;
    width: calc(100vw - 32px);
    margin: 10vh auto 0;
  }
  .dialog::backdrop {
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }
  .box {
    background: var(--color-bg-inner);
    border: 1px solid var(--color-lines);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .input-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    border-bottom: 1px solid var(--color-lines);
    color: var(--color-muted);
  }
  .input-row input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--color-fg);
    font: inherit;
    font-size: var(--fs-base);
  }
  .results {
    list-style: none;
    margin: 0;
    padding: 6px;
    max-height: 60vh;
    overflow-y: auto;
  }
  .results li a {
    display: block;
    padding: 10px 12px;
    border-radius: var(--radius);
    color: var(--color-fg);
  }
  .results li a:hover {
    background: var(--color-bg-hover);
    text-decoration: none;
  }
  .hit-title {
    font-weight: 500;
  }
  .hit-excerpt {
    font-size: var(--fs-sm);
    color: var(--color-muted);
    margin-top: 2px;
  }
  .hit-info,
  .hit-error {
    padding: 16px 20px;
    color: var(--color-muted);
    font-size: var(--fs-sm);
    text-align: center;
  }
  .hit-error {
    color: var(--color-fg);
  }
</style>
