---
import type { SidebarNode } from "../lib/sidebar";
import Self from "./SidebarNode.astro";

interface Props {
  node: SidebarNode;
  currentHref: string;
}
const { node, currentHref } = Astro.props;
const isLeaf = !!node.href;
const isActive = node.href === currentHref;
---
{isLeaf ? (
  <li class="item">
    <a href={node.href} class={isActive ? "active" : ""}>{node.label}</a>
  </li>
) : (
  <li class="group-wrap">
    <div class="group">{node.label}</div>
    <ul class="children">
      {node.children?.map((child) => <Self node={child} currentHref={currentHref} />)}
    </ul>
  </li>
)}

<style>
  .item { padding: .0625em 0; }
  a {
    color: var(--color-muted);
    padding: .375em .625em;
    border-radius: var(--radius);
    display: block;
    transition: background-color .1s, color .1s;
  }
  a:hover {
    color: var(--color-fg);
    text-decoration: none;
    background: var(--color-surface-hover);
  }
  a.active {
    color: var(--color-fg);
    background: var(--color-surface);
    font-weight: 500;
  }
  .group {
    margin: 0 0 .25em;
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: .05em;
    color: var(--color-subtle);
    padding: 0 .625em;
    font-weight: 600;
  }
  .children {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  /* Top-level group separator — a line above each group after the first. */
  .group-wrap {
    padding-top: 1em;
    margin-top: 1em;
    border-top: 1px solid var(--color-border);
  }
  .group-wrap:first-child {
    padding-top: 0;
    margin-top: 0;
    border-top: none;
  }
  /* Nested groups (inside .children) don't get their own separator. */
  .children .group-wrap {
    padding-top: .5em;
    margin-top: .5em;
    border-top: none;
  }
</style>
