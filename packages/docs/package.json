    "./styles/tokens.css": "./src/styles/tokens.css",
    "./routes/*": "./src/routes/*"
  },
  "peerDependencies": {
    "astro": "^6.0.0"
  },
  "dependencies": {
    "pagefind": "^1.5.2",
    "rehype-slug": "^6.0.0",
    "unist-util-visit": "^5.1.0",
    "yaml": "^2.8.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@types/node": "^25.6.0",
    "astro": "^6.1.7",
    "typescript": "^5.9.3",
    "vite": "^7.0.0",
    "vitest": "^4.1.4"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ]
