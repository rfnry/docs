{
  "name": "@rfnry/docs",
  "version": "0.2.0",
  "type": "module",
  "description": "rfnry/docs — Astro documentation template",
  "author": "rfnry (https://github.com/rfnry)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rfnry/docs.git",
    "directory": "packages/docs"
  },
  "homepage": "https://github.com/rfnry/docs",
  "bugs": "https://github.com/rfnry/docs/issues",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "rfnry",
    "astro",
    "documentation",
    "docs",
    "agent",
    "ai",
    "llms-txt"
  ],
  "engines": {
