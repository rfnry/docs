---
import type { SidebarNode } from "../lib/sidebar";
import { containsHref } from "../lib/sidebar";
import Self from "./SidebarNode.astro";
import Icon from "@rfnry/ui/components/Icon.astro";

interface Props {
  node: SidebarNode;
  currentHref: string;
}
const { node, currentHref } = Astro.props;
const isLeaf = !!node.href;
const isActive = node.href === currentHref;
const hasActive = isLeaf ? false : containsHref(node, currentHref);
const initiallyOpen = !node.collapsed || hasActive;
---
{isLeaf ? (
  <li class="item">
    <a href={node.href} class={isActive ? "active" : ""}>{node.label}</a>
  </li>
) : (
  <li class="group-wrap">
    <details open={initiallyOpen}>
      <summary class="group">
        <span class="group-row">
          <span class="chev"><Icon name="chevron-right" size={12} /></span>
          <span class="group-label">{node.label}</span>
        </span>
      </summary>
      <ul class="children">
        {node.children?.map((child) => <Self node={child} currentHref={currentHref} />)}
      </ul>
    </details>
  </li>
)}

<style>
  .item { padding: .0625em 0; }
  a {
    color: var(--color-muted);
    padding: .25em 0;
    display: block;
    transition: color .1s;
  }
  a:hover {
    color: var(--color-fg);
    text-decoration: none;
  }
  a.active {
    color: var(--color-fg);
    font-weight: 500;
  }

  details { padding: 0; }
  summary.group {
    list-style: none;
    cursor: pointer;
    padding: .25em 0;
    margin: 0 0 .25em;
    user-select: none;
  }
  summary.group::-webkit-details-marker { display: none; }
  summary.group::marker { content: ""; }

  .group-row {
    display: inline-flex;
    align-items: center;
    gap: .5em;
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: .05em;
    color: var(--color-subtle);
    font-weight: 600;
    transition: color .1s;
  }
  summary.group:hover .group-row { color: var(--color-fg); }
  .chev {
    display: inline-flex;
    flex-shrink: 0;
    transition: transform .15s;
  }
  details[open] > summary.group .chev { transform: rotate(90deg); }

  .children {
    list-style: none;
    margin-left: 5px;
    padding: 0 0 0 .75em;
    border-left: 1px solid var(--color-tree-line);
  }

  .group-wrap {
    padding-top: 1em;
    margin-top: 1em;
    border-top: 1px solid var(--color-lines);
  }
  .group-wrap:first-child {
    padding-top: 0;
    margin-top: 0;
    border-top: none;
  }
  .children .group-wrap {
    padding-top: 0;
    margin-top: .25em;
    border-top: none;
  }
</style>
