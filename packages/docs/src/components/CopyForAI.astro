---
import Button from "@rfnry/ui/components/Button.astro";
import Icon from "@rfnry/ui/components/Icon.astro";

interface Props {
  url: string;
  anchor?: string;
  label?: string;
}
const { url, anchor, label = "Copy Markdown" } = Astro.props;
---
<Button
  class="copy-ai"
  data-copy-ai
  data-copy-ai-url={url}
  data-copy-ai-anchor={anchor}
  aria-label="Copy this content as markdown for an AI assistant"
>
  <Icon name="copy" size={14} />
  <span data-copy-ai-label>{label}</span>
</Button>
