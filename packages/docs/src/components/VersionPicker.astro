---
import { config as docsConfig } from "virtual:@rfnry/docs/config";
import Dropdown from "./primitives/Dropdown.astro";

interface Props {
  currentLocale: string;
  currentVersion: string;
}
const { currentLocale, currentVersion } = Astro.props;
const currentLabel = docsConfig.versions.find((v) => v.id === currentVersion)?.label ?? currentVersion;
---
<Dropdown id="version" align="left" variant="select" label="Change version">
  <Fragment slot="trigger">{currentLabel}</Fragment>
  <Fragment slot="menu">
    {docsConfig.versions.map((v) => (
      <a href={`/${currentLocale}/${v.id}/`} class={v.id === currentVersion ? "active" : ""}>
        {v.label}{v.current ? " (current)" : ""}
      </a>
    ))}
  </Fragment>
</Dropdown>
