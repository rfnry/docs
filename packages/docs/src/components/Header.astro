---
import { config as docsConfig } from "virtual:@rfnry/docs/config";
import LocalePicker from "./LocalePicker.astro";
import PackagePicker from "./PackagePicker.astro";
import Search from "./Search.astro";
import ShareAI from "./ShareAI.astro";
import SocialLinks from "./SocialLinks.astro";
import ThemeToggle from "@rfnry/ui/components/ThemeToggle.astro";
import VersionPicker from "./VersionPicker.astro";
import Button from "@rfnry/ui/components/Button.astro";
import Icon from "@rfnry/ui/components/Icon.astro";

interface Props {
  currentLocale: string;
  currentPkg: string;
  currentVersion: string;
  currentSlug: string;
}
const { currentLocale, currentPkg, currentVersion, currentSlug } = Astro.props;
const showLogo = docsConfig.site.logo.enabled;
---
<header class="header">
  <div class="inner">
    <div class="left">
      <Button
        variant="icon"
        class="hamburger"
        data-mobile-nav-toggle
        aria-label="Toggle navigation"
        aria-expanded="false"
      >
        <span class="hamburger-icon hamburger-icon-menu"><Icon name="menu" size={18} /></span>
        <span class="hamburger-icon hamburger-icon-close"><Icon name="x" size={18} /></span>
      </Button>
      <a href={`/${currentLocale}/${currentPkg}/${currentVersion}/`} class="brand">
        {showLogo && (
          <img src={docsConfig.site.logo.src} alt={docsConfig.site.logo.alt} class="logo" />
        )}
        <span class="brand-text">{docsConfig.site.title}</span>
      </a>
      <span class="desktop-only pickers">
        <PackagePicker currentLocale={currentLocale} currentPkg={currentPkg} />
        <VersionPicker currentLocale={currentLocale} currentPkg={currentPkg} currentVersion={currentVersion} />
      </span>
    </div>
    <div class="spacer" aria-hidden="true"></div>
    <div class="right">
      <Search />
      <div class="desktop-only header-desktop-items">
        <ShareAI />
        {docsConfig.headerLinks.map((l) => (
          <a href={l.href} class="link" target={l.external ? "_blank" : undefined} rel={l.external ? "noopener" : undefined}>
            {l.label}
          </a>
        ))}
        <SocialLinks />
        <LocalePicker currentLocale={currentLocale} currentPkg={currentPkg} currentVersion={currentVersion} currentSlug={currentSlug} />
        <ThemeToggle />
      </div>
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    height: var(--header-h);
    background: var(--color-bg-inner);
    border-bottom: 1px solid var(--color-lines);
  }
  .inner {
    max-width: var(--shell-max, 1280px);
    margin: 0 auto;
    height: 100%;
    padding: 0 var(--gutter);
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 12px;
    align-items: center;
  }
  .left,
  .right {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
  }
  .pickers {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    flex-shrink: 0;
  }
  .brand:hover {
    text-decoration: none;
  }
  .logo {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }
  .link {
    font-size: var(--fs-sm);
    color: var(--color-muted);
    padding: 0.375em 0.5em;
    flex-shrink: 0;
  }
  .link:hover {
    color: var(--color-fg);
    text-decoration: none;
  }
  .header-desktop-items {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  :global(.hamburger) {
    display: none;
    position: relative;
  }
  .hamburger-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .hamburger-icon-close {
    display: none;
  }
  :global(body[data-sidebar-open="true"]) .hamburger-icon-menu {
    display: none;
  }
  :global(body[data-sidebar-open="true"]) .hamburger-icon-close {
    display: inline-flex;
  }

  @media (max-width: 768px) {
    .desktop-only {
      display: none !important;
    }
    :global(.hamburger) {
      display: inline-flex;
    }
  }
</style>

<script>
  import { initMobileSidebar } from "../scripts/mobile-sidebar.ts";
  initMobileSidebar();
</script>
