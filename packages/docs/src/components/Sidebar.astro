---
import { getCollection } from "astro:content";
import { buildSidebarTree, type SidebarNode } from "../lib/sidebar";
import { loadGroups } from "../lib/groups";
import Nav from "@rfnry/ui/components/Nav.astro";
import type { NavItem } from "@rfnry/ui/lib/nav";

interface Props {
  locale: string;
  pkg: string;
  version: string;
  currentHref: string;
}
const { locale, pkg, version, currentHref } = Astro.props;

function toNavItem(n: SidebarNode, path: string): NavItem {
  const id = n.href ?? `group:${path}`;
  return {
    id,
    label: n.label,
    href: n.href,
    defaultOpen: !n.collapsed,
    children: n.children?.map((c, i) => toNavItem(c, `${path}/${i}`)),
  };
}

const entries = await getCollection("docs");
const simpleEntries = entries.map((e) => ({
  id: e.id,
  title: e.data.sidebar.label ?? e.data.title,
  order: e.data.sidebar.order,
  hidden: e.data.sidebar.hidden,
}));
const groups = loadGroups(pkg, version, locale);
const tree = buildSidebarTree({ pkg, version, locale, entries: simpleEntries, groups });
const items = tree.map((n, i) => toNavItem(n, String(i)));
---
<Nav items={items} currentHref={currentHref} ariaLabel="Documentation navigation" />
