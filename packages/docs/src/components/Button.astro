---
import Icon from "./Icon.astro";

interface Props {
  variant?: "filled" | "icon" | "select";
  bare?: boolean;
  href?: string;
  class?: string;
  [key: string]: unknown;
}
const { variant = "filled", bare, href, class: className, ...rest } = Astro.props;
const extraAttrs: Record<string, unknown> = href ? { href } : { type: "button" };
const Tag = (href ? "a" : "button") as "a";
---
<Tag
  {...rest}
  {...extraAttrs}
  class:list={["btn", `btn-${variant}`, bare && "btn-bare", className]}
>
  {variant === "select" ? (
    <>
      <span class="btn-body"><slot /></span>
      <span class="btn-chev" aria-hidden="true"><Icon name="chevron-down" size={12} /></span>
    </>
  ) : (
    <slot />
  )}
</Tag>

<style is:global>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    box-sizing: border-box;
    height: var(--btn-h);
    padding: 0 10px;
    font-size: var(--fs-sm);
    color: var(--color-muted);
    background: var(--color-button-bg);
    border: 1px solid var(--color-lines);
    border-radius: var(--radius);
    cursor: pointer;
    white-space: nowrap;
    text-decoration: none;
    transition:
      color 0.1s,
      border-color 0.1s,
      background-color 0.1s;
  }
  .btn:hover,
  .btn[aria-expanded="true"] {
    color: var(--color-fg);
  }
  .btn:disabled {
    opacity: 0.6;
    cursor: wait;
  }

  .btn-icon {
    width: var(--btn-h);
    padding: 0;
    flex-shrink: 0;
  }

  .btn-select .btn-body {
    display: inline-flex;
    align-items: center;
    padding-left: 12px;
  }
  .btn-chev {
    display: inline-flex;
    flex-shrink: 0;
    transition: transform 0.15s;
  }
  .btn[aria-expanded="true"] .btn-chev {
    transform: rotate(180deg);
  }

  .btn-bare {
    background: transparent;
    border-color: transparent;
  }
  .btn-bare:hover,
  .btn-bare[aria-expanded="true"] {
    background: transparent;
    border-color: transparent;
    color: var(--color-fg);
  }
  .btn-bare.btn-select {
    height: auto;
    padding: 0;
  }
  .btn-bare.btn-select .btn-body {
    padding-left: 0;
    line-height: 14px;
  }
</style>
