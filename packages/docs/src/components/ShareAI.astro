---
import Dropdown from "./Dropdown.astro";
import Icon from "./Icon.astro";
---
<Dropdown id="share" align="right" variant="icon" label="Share">
  <Fragment slot="trigger">
    <Icon name="share" size={16} />
  </Fragment>
  <Fragment slot="menu">
    <button type="button" data-share-action="link">
      <span data-share-label>Share URL</span>
    </button>
    <button type="button" data-share-action="ai">
      <span data-share-label>Share llms.txt</span>
    </button>
  </Fragment>
</Dropdown>

<script>
  import { initShare } from "../scripts/share-ai.ts";
  initShare();
</script>
