---
import { config as docsConfig } from "virtual:@rfnry/docs/config";
import Button from "@rfnry/ui/components/Button.astro";
import Icon from "@rfnry/ui/components/Icon.astro";

interface Props {
  pkg: string;
  version: string;
}
const { pkg, version } = Astro.props;
const pagefindUrl = `${docsConfig.base}pagefind/pagefind.js`;
---
<Button class="search-trigger" data-search-trigger aria-label="Search">
  <Icon name="search" size={14} />
  <span class="search-label">Search…</span>
</Button>

<dialog
  class="dialog"
  data-search-dialog
  data-pagefind-url={pagefindUrl}
  data-search-package={pkg}
  data-search-version={version}
>
  <div class="box">
    <div class="input-row">
      <Icon name="search" size={16} />
      <input type="search" name="q" placeholder="Search docs" data-search-input aria-label="Search docs" />
    </div>
    <ul class="results" data-search-results></ul>
  </div>
</dialog>

<script>
  import { initSearch } from "../scripts/search.ts";
  document.addEventListener("astro:page-load", initSearch);
  initSearch();
</script>

<style>
  :global(.search-trigger) {
    width: 100%;
    max-width: 400px;
    min-width: 240px;
    gap: 8px;
    padding: 0 10px;
    justify-content: flex-start;
  }
  .search-label {
    flex: 1;
    text-align: left;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 768px) {
    :global(.search-trigger) {
      width: var(--btn-h);
      min-width: 0;
      padding: 0;
      justify-content: center;
      flex-shrink: 0;
    }
    .search-label {
      display: none;
    }
  }

  .dialog {
    padding: 0;
    border: none;
    background: transparent;
    max-width: 640px;
    width: calc(100vw - 32px);
    margin: 10vh auto 0;
  }
  .dialog::backdrop {
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }
  .box {
    background: var(--color-bg-inner);
    border: 1px solid var(--color-lines);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .input-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    border-bottom: 1px solid var(--color-lines);
    color: var(--color-muted);
  }
  .input-row input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--color-fg);
    font: inherit;
    font-size: var(--fs-base);
  }
  .results {
    list-style: none;
    margin: 0;
    padding: 6px;
    max-height: 60vh;
    overflow-y: auto;
  }
  .results li a {
    display: block;
    padding: 10px 12px;
    border-radius: var(--radius);
    color: var(--color-fg);
  }
  .results li a:hover {
    background: var(--color-bg-hover);
    text-decoration: none;
  }
  .hit-title {
    font-weight: 500;
  }
  .hit-excerpt {
    font-size: var(--fs-sm);
    color: var(--color-muted);
    margin-top: 2px;
  }
  .hit-info,
  .hit-error {
    padding: 16px 20px;
    color: var(--color-muted);
    font-size: var(--fs-sm);
    text-align: center;
  }
  .hit-error {
    color: var(--color-fg);
  }
</style>
