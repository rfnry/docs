---
import { getCollection, render } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
import TOC from "../components/TOC.astro";
import CopyForAI from "../components/CopyForAI.astro";
import PrevNext from "../components/PrevNext.astro";
import PackagePicker from "../components/PackagePicker.astro";
import VersionPicker from "../components/VersionPicker.astro";
import LocalePicker from "../components/LocalePicker.astro";
import ShareAI from "../components/ShareAI.astro";
import Shell from "@rfnry/ui/components/Shell.astro";
import SocialLinksDropdown from "@rfnry/ui/components/SocialLinksDropdown.astro";
import ThemeToggle from "@rfnry/ui/components/ThemeToggle.astro";
import { parseEntryId, buildDocHref } from "../lib/routing";
import { sliceSections, buildContextHeader } from "../lib/ai-content";
import { config as docsConfig } from "virtual:@rfnry/docs/config";

export async function getStaticPaths() {
  const entries = await getCollection("docs");
  return entries.map((entry) => {
    const parsed = parseEntryId(entry.id);
    return {
      params: {
        locale: parsed.locale,
        pkg: parsed.pkg,
        version: parsed.version,
        slug: parsed.slug || undefined,
      },
      props: { entry, parsed },
    };
  });
}

const { entry, parsed } = Astro.props;
const { Content, headings } = await render(entry);
const currentHref = buildDocHref(parsed, docsConfig.base);
const mdUrl = `${currentHref.replace(/\/$/, "")}.md`;
const canonicalUrl = docsConfig.site.url + currentHref;

const sections = sliceSections(entry.body as string).map((s) => ({
  anchor: s.anchor,
  payload:
    buildContextHeader({
      url: canonicalUrl,
      pkg: parsed.pkg,
      version: parsed.version,
      locale: parsed.locale,
      anchor: s.anchor,
    }) + s.markdown,
}));
---
<Layout
  title={entry.data.title}
  description={entry.data.description}
  locale={parsed.locale}
  pkg={parsed.pkg}
  version={parsed.version}
>
  <Shell sidebar toc>
    <Fragment slot="header">
      <Header currentLocale={parsed.locale} currentPkg={parsed.pkg} currentVersion={parsed.version} currentSlug={parsed.slug} />
    </Fragment>
    <Fragment slot="sidebar">
      <div class="sidebar-main">
        <Sidebar locale={parsed.locale} pkg={parsed.pkg} version={parsed.version} currentHref={currentHref} />
      </div>
      <div class="mobile-footer">
        <div class="mobile-footer-cluster">
          <PackagePicker currentLocale={parsed.locale} currentPkg={parsed.pkg} />
          <VersionPicker currentLocale={parsed.locale} currentPkg={parsed.pkg} currentVersion={parsed.version} />
        </div>
        <div class="mobile-footer-cluster">
          <ShareAI locale={parsed.locale} pkg={parsed.pkg} version={parsed.version} />
          <SocialLinksDropdown social={docsConfig.site.social} />
          <LocalePicker currentLocale={parsed.locale} currentPkg={parsed.pkg} currentVersion={parsed.version} currentSlug={parsed.slug} />
          <ThemeToggle />
        </div>
      </div>
    </Fragment>
    <div data-pagefind-body data-pagefind-filter={`package:${parsed.pkg}|version:${parsed.version}`} lang={parsed.locale}>
      <article class="prose">
        <header class="page-header">
          <h1 data-pagefind-meta="title">{entry.data.title}</h1>
          <CopyForAI url={mdUrl} />
        </header>
        <Content />
      </article>
      <PrevNext locale={parsed.locale} pkg={parsed.pkg} version={parsed.version} currentHref={currentHref} />
      {sections.map((s) => (
        <template id={`section-md-${s.anchor}`} data-payload={JSON.stringify(s.payload)}></template>
      ))}
    </div>
    <Fragment slot="toc">
      <TOC headings={headings} />
    </Fragment>
  </Shell>
</Layout>

<script define:vars={{ mdUrl }}>
  document.querySelectorAll("article.prose h2[data-section-heading]").forEach((h2) => {
    if (h2.querySelector(".copy-ai")) return;
    const anchor = h2.getAttribute("data-section-heading");
    const btn = document.createElement("button");
    btn.type = "button";
    btn.className = "btn copy-ai section";
    btn.setAttribute("data-copy-ai", "");
    btn.setAttribute("data-copy-ai-url", mdUrl);
    btn.setAttribute("data-copy-ai-anchor", anchor);
    btn.setAttribute("aria-label", `Copy section "${h2.textContent}" for AI`);
    const span = document.createElement("span");
    span.setAttribute("data-copy-ai-label", "");
    span.textContent = "Copy";
    btn.appendChild(span);
    h2.appendChild(btn);
  });
</script>

<script>
  import { initCopyForAI } from "../scripts/copy-ai.ts";
  import { initCodeCopy } from "../scripts/code-copy.ts";
  initCopyForAI();
  initCodeCopy();
</script>

<style>
  .sidebar-main {
    display: block;
  }
  .mobile-footer {
    display: none;
  }
  .page-header {
    display: flex;
    align-items: center;
    gap: var(--gutter);
    margin-bottom: 1.5em;
  }
  .page-header h1 {
    margin: 0;
    flex: 1;
  }

  @media (max-width: 768px) {
    .sidebar-main {
      flex: 1;
      overflow-y: auto;
    }
    .mobile-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px var(--gutter);
      border-top: 1px solid var(--color-lines);
      background: var(--color-bg-inner);
      flex-shrink: 0;
    }
    .mobile-footer-cluster {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .mobile-footer :global(.dropdown-menu) {
      top: auto;
      bottom: calc(100% + 6px);
    }
  }
</style>
