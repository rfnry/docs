{
  "name": "rfnry-docs",
  "version": "0.1.0",
  "type": "module",
  "description": "Astro integration for minimal, opinionated documentation sites with versioning, i18n, and first-class AI endpoints.",
  "author": "Fernando Vargas <frndvrgs> (https://frndvrgs.com)",
  "repository": "github:rfnry/docs",
  "homepage": "https://github.com/rfnry/docs",
  "license": "MIT",
  "keywords": [
    "astro",
    "astro-integration",
    "documentation",
    "docs",
    "i18n",
    "versioning",
    "llms-txt",
    "ai"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./components/*": "./src/components/*",
    "./content": "./src/content/config.ts",
    "./styles/tokens.css": "./src/styles/tokens.css",
    "./routes/*": "./src/routes/*"
  },
  "peerDependencies": {
    "astro": "^6.0.0",
    "pagefind": "^1.5.2"
  },
  "peerDependenciesMeta": {
    "pagefind": {
      "optional": true
    }
  },
  "dependencies": {
    "rehype-slug": "^6.0.0",
    "unist-util-visit": "^5.1.0",
    "yaml": "^2.8.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@types/node": "^25.6.0",
    "astro": "^6.1.7",
    "typescript": "^5.9.3",
    "vite": "^7.0.0",
    "vitest": "^4.1.4"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ]
}
